# ──────────────────────────────────────────────────────────────
# Parity — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Database (PostgreSQL on parity-postgres:5432 inside the network) ──
POSTGRES_HOST=parity-postgres
POSTGRES_PORT=5432
POSTGRES_DB=parity
POSTGRES_USER=parity
POSTGRES_PASSWORD=

# ── ChromaDB (vector store on parity-chromadb:8000 inside the network) ──
CHROMADB_HOST=parity-chromadb
CHROMADB_PORT=8000

# ── Google Cloud / Gemini (Vertex AI) ──────────────────────────
# Set GOOGLE_GENAI_USE_VERTEXAI=true to route Gemini calls through Vertex
# (uses Application Default Credentials, not an API key). Run
#   gcloud auth application-default login
# on the host once; mount the resulting credentials into the backend
# container if running outside Cloud Run.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=parity-dynatrace
GOOGLE_CLOUD_LOCATION=us-central1
# Model IDs MUST be specific Vertex publisher names — *-latest aliases do
# NOT resolve on Vertex (they only work on the AI Studio API). Confirmed
# working in us-central1 on 2026-05-13: gemini-2.5-flash, gemini-2.5-pro,
# gemini-2.5-flash-lite. Gemini 2.5 emits "thoughts" tokens before reply
# so generationConfig.maxOutputTokens needs healthy headroom (>= 256).
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# ── Dynatrace MCP ──────────────────────────────────────────────
# DT_MCP_URL points at the MCP server's streamable-HTTP endpoint.
# Default is the in-stack stub (parity-dt-mcp). Swap to the real
# @dynatrace-oss/dynatrace-mcp-server in Rewire 3.
DT_MCP_URL=http://parity-dt-mcp:8000/mcp
# Used by the real Dynatrace MCP — must be apps.dynatrace.com, NOT .live.dynatrace.com
DT_ENVIRONMENT=
DT_PLATFORM_TOKEN=
# Optional — Grail query budget cap
DT_GRAIL_QUERY_BUDGET_GB=1000

# ── Grafana (device inventory source) ──────────────────────────
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=

# ── pyATS (network device automation) ──────────────────────────
PYATS_USERNAME=
PYATS_PASSWORD=
PYATS_CONNECT_TIMEOUT=60
PYATS_COMMAND_TIMEOUT=30

# ── Jira ──────────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PRTY

# ── Slack ─────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# ── Application ───────────────────────────────────────────────
SNAPSHOT_SCHEDULE_CRON=*/15 * * * *
APPROVAL_EXPIRY_HOURS=24
LOG_LEVEL=INFO
